{
  "Datacenter": {
    "Description": "AWS VPC",
    "Name": "aws-datacenter",
    "Cidr": "10.0.0.0/16",
    "Region": "eu-west-1",
    "InternetGateway": "aws-gateway",
    "RouteTable": "aws-routetable",
    "Subnets": [
      {
        "Description": " AWS network shared by the instances.",
        "Name": "admin-subnet",
        "Az": "eu-west-1a",
        "Cidr": "10.0.20.0/24"
      }
    ],
    "SecurityGroups": [
      {
        "Description": "Admin instance security group.",
        "Name": "admin-sgp",
        "Rules": [
          {
            "FromPort": -1,
            "ToPort": -1,
            "Protocol": "icmp",
            "Cidr": "0.0.0.0/0",
            "Description": "ping access"
          },
          {
            "FromPort": 22,
            "ToPort": 22,
            "Protocol": "tcp",
            "Cidr": "0.0.0.0/0",
            "Description": "ssh access"
          }
        ]
      }
    ],
    "Instances": [
      {
        "UserName": "awsadmin",
        "UserPassword": "awsadmin",
        "PrivateIp": "10.0.20.35",
        "SecurityGroup": "admin-sgp",
        "Subnet": "admin-subnet",
        "ParentImage": "amzn2-ami-kernel-5.10-hvm-2.0.20230719.0-x86_64-gp2",
        "DnsName": "admin.maxmin.it",
        "HostName": "admin.maxmin.it",
        "Tags": [
          {
            "__description_": "tag Name is unique for each AWS instance.",  
            "Key": "Name",
            "Value": "admin-box"
          },
          {
            "Key": "Class",
            "Value": "cms"
          },
          {
            "Key": "Database",
            "Value": "postgresql"
          },
          {
            "Key": "Program",
            "Value": "python"
          },
          {
            "Key": "Security",
            "Value": "openssl"
          },
          {
            "Key": "Webserver",
            "Value": "nginx"
          }
        ]
      }
    ]
  }
}
